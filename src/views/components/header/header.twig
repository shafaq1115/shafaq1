{% set important_links = theme.settings.get('important_links') %}

<header class="store-header shafaq-header">

  <div class="shafaq-topbar">
    <div class="container shafaq-topbar__inner">
      <div class="shafaq-topbar__right">
        <span>متجر شفق الشرق للتجارة</span>
        <span>مستلزمات طبية | كراسي كهربائية | رعاية منزلية</span>
      </div>

      <div class="shafaq-topbar__left">
        <span>الشحن داخل السعودية</span>
        <span>دعم العملاء</span>
        <salla-contacts is-header></salla-contacts>
      </div>
    </div>
  </div>

  <div class="shafaq-mainnav" id="mainnav">
    <div class="container shafaq-mainnav__inner">

      <a class="lg:hidden mburger mburger--collapse leading-none" href="#mobile-menu" aria-label="Open-menu">
        <i class="sicon-menu text-2xl"></i>
      </a>

      <a class="navbar-brand shafaq-logo" href="{{ store.url }}">
        <img fetchpriority="high" loading="eager" src="{{ store.logo|cdn(190) }}" alt="{{ store.name }} logo">
        {% if is_page('index') %}
          <h1 class="sr-only">{{ store.name }}</h1>
        {% else %}
          <h2 class="sr-only">{{ store.name }}</h2>
        {% endif %}
      </a>

      <div class="shafaq-search">
        <salla-search inline oval height="48"></salla-search>
      </div>

      <div class="shafaq-actions">
        <salla-user-menu avatar-only show-header show-trigger></salla-user-menu>
        <salla-cart-summary>
          <i slot="icon" class="header-btn__icon icon sicon-shopping-bag"></i>
        </salla-cart-summary>
      </div>

    </div>
  </div>

  <div class="shafaq-menu">
    <div class="container shafaq-menu__inner">
      <a href="{{ store.url }}">الرئيسية</a>
      <a href="/categories">وسائل المساعدة على الحركة</a>
      <a href="/categories">الرعاية المنزلية</a>
      <a href="/categories">الأجهزة الطبية المنزلية</a>
      <a href="/categories">العلاج الطبيعي والتأهيل</a>
      <a href="/categories">العناية بالقدم والسكري</a>
      <a href="/categories">تجهيز المستشفيات والعيادات</a>
      <a href="/offers" class="shafaq-menu__offer">العروض</a>
    </div>
  </div>

</header>